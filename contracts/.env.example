# ──────────────────────────────────────────
# RunChain 컨트랙트 환경 변수
# 이 파일을 .env로 복사 후 실제 값 입력
# .env는 절대 깃허브에 올리지 말 것!
# ──────────────────────────────────────────

# 배포 지갑 프라이빗 키 (테스트 전용 지갑 새로 생성 권장)
PRIVATE_KEY=your_private_key_here

# BSC 테스트넷 RPC
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545

# BSC 메인넷 RPC
BSC_MAINNET_RPC=https://bsc-dataseed.binance.org/

# BSCScan API Key (컨트랙트 검증용)
# https://bscscan.com/myapikey 에서 발급
BSCSCAN_API_KEY=your_bscscan_api_key_here

# 백엔드 서버 지갑 주소 (verifier)
# submitRecord, finalizeChallenge 등을 호출할 서버 지갑
VERIFIER_ADDRESS=your_verifier_wallet_address_here

# 배포 후 컨트랙트 주소 (배포 완료 시 기입)
CONTRACT_ADDRESS_TESTNET=
CONTRACT_ADDRESS_MAINNET=
